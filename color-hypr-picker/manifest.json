{
  "id": "color-hypr-picker",
  "name": "Color (hypr)picker",
  "version": "1.0.0",
  "minNoctaliaVersion": "4.3.2",
  "author": "off94",
  "license": "MIT",
  "repository": "https://github.com/off94/noctalia-plugins",
  "description": "A color picker plugin that extends Noctalia's base one with hyprpicker. Paste several color codes to your clipboard, and browse recent colors list.",
